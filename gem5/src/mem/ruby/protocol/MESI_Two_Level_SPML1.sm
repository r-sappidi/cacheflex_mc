  // C3: SPM helper action added in checkpoint 3.
  action(spm_recordRequestMetadata, "srm",
         desc="Record SPM request metadata in the TBE") {
    peek(mandatoryQueue_in, RubyRequest) {
      assert(is_valid(tbe));
      tbe.SrcAddr := makeLineAddress(in_msg.SrcAddr); // C8
      tbe.DstSPMAddr := makeLineAddress(in_msg.DstSPMAddr); // C8
      tbe.SPMSet := in_msg.SPMSet; // C6
      tbe.SPMWay := in_msg.SPMWay; // C6
      tbe.Len := in_msg.Size;
    }
  }

  // C3: SPM helper action added in checkpoint 3.
  action(spm_issueGETSSilent, "sgs",
         desc="Issue GETS_SILENT for SPMCP_fetch source miss") {
    peek(mandatoryQueue_in, RubyRequest) {
      enqueue(requestL1Network_out, RequestMsg, l1_request_latency) {
        out_msg.addr := tbe.SrcAddr; // C8: coherent source address.
        out_msg.SrcAddr := tbe.SrcAddr; // C8
        out_msg.DstSPMAddr := tbe.DstSPMAddr;
        out_msg.Len := tbe.Len;
        out_msg.Type := CoherenceRequestType:GETS_SILENT;
        out_msg.Requestor := machineID;
        out_msg.Destination.add(mapAddressToRange(tbe.SrcAddr, MachineType:L2Cache, // C8
                          l2_select_low_bit, l2_select_num_bits, intToID(0)));
        out_msg.MessageSize := MessageSizeType:Control;
        out_msg.Prefetch := in_msg.Prefetch;
        out_msg.AccessMode := in_msg.AccessMode;
      }
    }
  }

  // C3: SPM helper action added in checkpoint 3.
  action(spm_issuePUTS, "sps",
         desc="Release shared coherent source for SPMCP_fetch") {
    enqueue(requestL1Network_out, RequestMsg, l1_request_latency) {
      out_msg.addr := tbe.SrcAddr; // C8: coherent source address.
      out_msg.SrcAddr := tbe.SrcAddr; // C8
      out_msg.DstSPMAddr := tbe.DstSPMAddr;
      out_msg.Len := tbe.Len;
      out_msg.Type := CoherenceRequestType:PUTS;
      out_msg.Requestor := machineID;
      out_msg.Destination.add(mapAddressToRange(tbe.SrcAddr, MachineType:L2Cache, // C8
                        l2_select_low_bit, l2_select_num_bits, intToID(0)));
      out_msg.MessageSize := MessageSizeType:Writeback_Control;
    }
  }

  // C3: SPM helper action added in checkpoint 3.
  action(spm_issuePUTM, "spm",
         desc="Release modified coherent source with data for SPMCP_fetch") {
    enqueue(requestL1Network_out, RequestMsg, l1_request_latency) {
      assert(is_valid(cache_entry));
      out_msg.addr := tbe.SrcAddr; // C8: coherent source address.
      out_msg.SrcAddr := tbe.SrcAddr; // C8
      out_msg.DstSPMAddr := tbe.DstSPMAddr;
      out_msg.Len := tbe.Len;
      out_msg.Type := CoherenceRequestType:PUTM;
      out_msg.DataBlk := cache_entry.DataBlk;
      out_msg.Dirty := true;
      out_msg.Requestor := machineID;
      out_msg.Destination.add(mapAddressToRange(tbe.SrcAddr, MachineType:L2Cache, // C8
                        l2_select_low_bit, l2_select_num_bits, intToID(0)));
      out_msg.MessageSize := MessageSizeType:Writeback_Data;
    }
  }

